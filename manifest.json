{
  "manifest_version": 3,
  "name": "Gage",
  "version": "0.0.1",
  "description": "Turn-by-turn board games on X — no API. Chess first; dev build.",
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*", "*://mastodon.social/*", "*://bsky.app/*"],
      "js": [
        "src/vendor/chess.js",
        "src/fen.js",
        "src/games/chess.js",
        "src/games/checkers.js",
        "src/games/reversi.js",
        "src/games/gomoku.js",
        "src/board.js",
        "src/seed.js",
        "src/board-image.js",
        "src/share.js",
        "src/transport/protocol.js",
        "src/transport/reconstruct.js",
        "src/transport/x.js",
        "src/transport/mastodon.js",
        "src/transport/bluesky.js",
        "src/transport/select.js",
        "src/transport/orchestration.js",
        "src/content.js"
      ],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ]
}
